  <sharedRules>
    <rule name="Flurry (x)" id="be5c-ee31-1819-b884" hidden="false" publicationId="dc00-d754-4c4e-532f" page="14">
      <description>When making an ATTACK Order with this weapon, each unmodified hit of X generates one additional successful hit.</description>
    </rule>
    <rule name="Riposte (+x dam)" id="91ae-2a01-e2aa-d841" hidden="false" publicationId="dc00-d754-4c4e-532f">
      <alias>Riposte</alias>
    </rule>
    <rule name="Disposable" id="1a42-8ac5-c965-6898" hidden="false" publicationId="dc00-d754-4c4e-532f" page="14">
      <description>If each friendly unit within range of enemy Melee weapons has the Disposable keyword, that enemy unit may be the target of shooting attacks, overriding the rule explained in the &quot;Attack Sequence” section. Before you roll any hit rolls for that Attack, select one friendly unit with the Disposable keyword. For each hit roll of 1 (with shooting weapons) that targets the enemy unit for that Attack Order, the selected friendly Disposable unit must make one save roll against that Attack as if they were the target of the Attack Order. Continue with this sequence after all Attacks against the enemy unit are completed.</description>
    </rule>
    <rule name="Champion" id="28f6-1ccd-70e4-3816" hidden="false" publicationId="dc00-d754-4c4e-532f" page="14">
      <description>Champions are individuals who have proven themselves worthy of leading, and have a few rules to show this. A Champion unit cannot be targeted by ranged attacks unless the attacking unit is within 12” unless there are no friendly Infantry or Elite units within 3” of the Champion</description>
    </rule>
    <rule name="Evade (-x)" id="b33a-b698-736b-bcf7" hidden="false" publicationId="dc00-d754-4c4e-532f" page="14">
      <description>When making an ATTACK Order with this weapon, decrease the target defending unit’s EVADE stat by (X) for the duration of that weapon&apos;s attack.</description>
    </rule>
    <rule name="Piercing" id="3f34-9009-582f-c130" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>When a save roll is made for an ATTACK Order made by this weapon, decrease the Armour type of the enemy unit by 1 step, to a minimum of Light.</description>
    </rule>
    <rule name="Bludgeoning" id="91bf-be2b-66c7-9575" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>When this weapon targets an enemy unit with Medium, Heavy or Super-Heavy armour, increase the damage characteristic by 1</description>
    </rule>
    <rule name="Subterranean" id="6335-dcdd-d307-30a2" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>Attacks with Subterranean cannot target units with the Flying keyword</description>
    </rule>
    <rule name="Payload" id="f2b0-d217-b0d0-54d2" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>Weapons with the Payload keyword are weapons with multiple profiles, a unit may only Fire with one of its Payload profiles per Attack Order</description>
    </rule>
    <rule name="Explosive (x)" id="f4dc-3c04-19d2-8ef0" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>After an ATTACK Order has been made with this weapon, select one unit targeted by that attack. Then, target each unit (friendly and enemy) within 3 inches of that unit and deal x Avoidable damage to each unit</description>
    </rule>
    <rule name="Penetrating" id="95fb-df0e-f739-a02e" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>After an ATTACK Order has been made for a unit with this weapon, select one enemy unit within 3” of the unit targeted by the ATTACK Order. That unit takes avoidable damage equal to the weapon’s damage for every model killed by the original ATTACK order.</description>
    </rule>
    <rule name="Infestation" id="fd88-b475-0d76-dcd4" hidden="false" publicationId="dc00-d754-4c4e-532f" page="15">
      <description>After an ATTACK order has been made for a unit with this weapon, target one unit that was dealt damage by the weapon. Models in that unit have -1 Intelligence until the end of the next turn, to a minimum of 0.</description>
    </rule>
    <rule name="Fire [Active] [Complexity 2]" id="efea-a772-9c17-7e95" hidden="false" publicationId="dc00-d754-4c4e-532f" page="16">
      <description>Your unit takes 1d4 avoidable damage. However, if they roll a 8 on that roll, select the closest friendly unit within 6”, that unit gains a Fire token. For each additional token on a unit, add 1 to the d4 roll.</description>
    </rule>
    <rule name="Poison [Active] [Complexity 2]" id="0463-8983-1b78-48c1" hidden="false">
      <description>Your unit takes 1d4 unavoidable damage. This damage can only kill one model for every activation of Poison. For each additional token, add 1 to the d4 roll.</description>
    </rule>
    <rule name="Stun [Passive] [Complexity 3]" id="d5b9-45c1-d256-547e" hidden="false" publicationId="dc00-d754-4c4e-532f" page="17">
      <description>For every Stun Effect Token on a unit, they receive -1 to their Move characteristic, to a minimum of 1.</description>
    </rule>
    <rule name="Webbed [Passive] [Complexity 1]" id="2e4f-5c5a-90e7-5a76" hidden="false" publicationId="dc00-d754-4c4e-532f" page="17">
      <description>For every Webbed Effect Token on a unit, they receive -1 to their Evade characteristic, to a minimum of 1.</description>
    </rule>
    <rule name="Weakness [Passive] [Complexity 2]" id="a23b-a381-c324-39da" hidden="false" publicationId="dc00-d754-4c4e-532f" page="17">
      <description>When a unit is inflicted with Weakness, they receive a -1 to skill for each Effect Token they are inflicted with.</description>
    </rule>
    <rule name="Fear [Passive] [Complexity 2]" id="2548-9c52-eaf3-9f1e" hidden="false" publicationId="dc00-d754-4c4e-532f" page="17">
      <description>Units that have a Fear token cannot gain the benefit of Cover.</description>
    </rule>
    <rule name="Single Use" id="04e4-783c-2768-1a13" hidden="false">
      <description>A Single Use weapon can only be fired once per battle for every model that has it.</description>
    </rule>
  </sharedRules>
